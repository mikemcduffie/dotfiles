SCRAPED_DIR = Path.home() / "scraped" / "stories"
LINKS_FILE = SCRAPED_DIR / "links.html"
FOUND_LINKS_FILE = SCRAPED_DIR / "found_links.html"
COMPLETED_LINKS_FILE = SCRAPED_DIR / "completed_links.html"

# https://stackoverflow.com/questions/15799696/how-to-build-urls-in-python-with-the-standard-library
