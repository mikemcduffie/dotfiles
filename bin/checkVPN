#          KILL_TRANSMISSION
#     fi
#     sleep 1
# done

#   killall Transmission && \
#   osascript -e \
#   "display alert \"VPN is OFF\" message \"IP: $IP_ADDR.\nTerminating Transmission...\""

# while true; do
#   if [[ $(pgrep Transmission) ]]; then
#       if [[  -z $(pgrep NordVPN) || -z $( ifconfig |  grep '\-\->')  ]]; then
#          echo VPN OFF
#          KILL_TRANSMISSION
#       fi
#
#   else
#       echo "Transmission not running. VPN check skipped."
#   fi
#   sleep 1
# done

