# readline keybindings:

  # Ctrl keys (key combo shortcuts)
    "^_" undo  # Ctrl-_ undo last typed char, paste etc.
    "^A" beginning-of-line  # Ctrl-A move to the beginning of line.
    "^B" backward-char  # Ctrl-B same as Left arrow.
    "^D" delete-char-or-list  # Ctrl-D deletes the character under the cursor if text present, else, on blank line it escapes the current shell.
    "^E" end-of-line  # Ctrl-E move to the end of line.
    "^F" forward-char  # Ctrl-F same as Right arrow.
    "^G" send-break
    "^H" backward-delete-char  # Ctrl-H same as Backspace.
    "^I" expand-or-complete
    "^J" accept-line
    "^K" kill-line  # Ctrl-K delete all text from the cursor to the end of line.
    "^L" clear-screen  # clear screen # Override to delete all test to beginning of line with "bindkey \^L backward-kill-line"
    "^M" accept-line
    "^N" down-line-or-history  # Ctrl-N same as Down arrow.
    "^O" accept-line-and-down-history
    "^P" up-line-or-history  # Ctrl-P same as Up arrow.
    "^Q" push-line  # MISMATCH: Ctrl-Q to resume output to terminal after Ctrl + s.
    "^R" history-incremental-search-backward  # Ctrl-R begins a backward search through command history.(keep pressing Ctrl + r to move backward)
    "^S" history-incremental-search-forward  # MISMATCH: Ctrl-S to stop output to terminal.
    "^T" transpose-chars  # Ctrl-T transpose the character before the cursor with the one under the cursor, press Esc + t to transposes the two words before the cursor.
    "^U" kill-whole-line  # Ctrl-U delete/clear the entire line
    "^W" backward-kill-word  # Ctrl-W delete the previous word 
    # Multi-step key sequence combos
    "^X^O" overwrite-mode
    "^X^U" undo
    "^Xa" _expand_alias
    "^Xc" _correct_word
    "^Xh" _complete_help
    Ctrl-X+Ctrl-E : launch editor defined by $EDITOR to input your command. Useful for multi-line commands.
    # Custom key combos (Note: example overrides clear default  action)
    Ctrl-L delete all text from cursor to the start of line: by adding "bindkey \^L backward-kill-line" to your zshrc file


# readline Change case
Meta-U # converts text from cursor to the end of the word to uppercase.
Meta-L # converts text from cursor to the end of the word to lowercase.
Meta-C # converts letter under the cursor to uppercase, rest of the word to lowercase.
