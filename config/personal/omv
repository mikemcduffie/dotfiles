## SSH to media and use bash as shell

# On omv.local server:

    # added media to _ssh group on omv.local (per allowed groups in /etc/ssh/sshd_config)
    sudo usermod -a -G _ssh media
    # or if ssh to root
    usermod -a -G _ssh media
    
    # switch user to media when ssh to root
    su media
    
    # added .ssh dir for user media 
    mkdir ~/.ssh & chmod 700 ~/.ssh

# On Mac
    ssh-keygen -t rsa -b 4096 -C "media@omv.local"
    ssh-copy-id -i .ssh/id_rsa.pub media@omv.local

    # ssh with key
    ssh -i .ssh/id_rsa 'media@omv.local'

## TIP
    # omv uses sh for users by default, change to bash
    chsh -s /bin/bash
    bash --version | head -1
    
    # Need to add media to sudo group
    sudo adduser media sudo




