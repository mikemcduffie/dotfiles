# merge .ass subtitles into similarly named MKV files
find -E . -maxdepth 1 -type f -iregex '.*\.(ASS|SRT)$' |\
  while read FILEPATH
  do
    DIRNAME=$(dirname "${FILEPATH}");
    BASENAME=$(basename "${FILEPATH}");
    FILENAME="${BASENAME%.*}";
    EXTENSION="${BASENAME##*.}"
    mkvmerge -o "$DIRNAME/${FILENAME}"-NEW.mkv "$DIRNAME/${FILENAME}".mp4 --language 0:eng --track-name 0:English "$DIRNAME/${FILENAME}"."${EXTENSION}"
  done
