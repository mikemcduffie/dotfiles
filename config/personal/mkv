# Add srt subs with language and forced flag
for file in *.mkv; do
  base="${file%.mkv}"
  mkvmerge -o "${base}_new.mkv" --default-track 0:yes --forced-track 0:yes --language 0:eng "$file" "${base}.srt"
done


