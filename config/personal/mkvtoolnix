# set audio track language
❯ mkvpropedit filename.mkv --edit track:a1 --set language="jpn"

# set forced flag for subtitle (srt) stream
❯ mkvpropedit filename.mkv --edit track:s1 --set flag-forced=1 

# set default flag for subtitle (srt) stream
❯ mkvpropedit filename.mkv --edit track:s1 --set flag-default=1 

# set multiple flags (srt, video, audio)
❯ mkvpropedit filename.mkv --edit track:s1 --set flag-default=1 --set flag-forced=1 --edit track:v1 --set language="jpn" --edit track:a1 --set language="jpn"

# function to use in loop for mkv edits (srt, video, audio)
❯ jmkv() { mkvpropedit "$1" --edit track:s1 --set flag-default=1 --set flag-forced=1 --set language="eng" --edit track:v1 --set language="jpn" --edit track:a1 --set language="jpn" }
❯ for f in *.mkv; do jmkv "$f"; done

# add srt file to video file (easy way; set flags, language with above)
❯ for f in *.mkv; do b="${f%.*}"; mkvmerge -o "merged/$f" "$f" "${b}.srt"; done 

# soft crop video: VideoStream#:Left,Top,Right,Bottom
❯ mkvmerge --cropping 1:0,6,0,0 file.mkv -o file_cropped.mkv