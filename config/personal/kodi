# Modern Kodi uses ActivateWindow native control in keyboard keymap to navigate
# Haven't investigated how this affects python integration
# add to ~/LibraryApplication Support/Kodi/userdata/keymaps/keyboard.xml
<keymap>
	<global>
		<keyboard>
			<n>NextAudioLanguage</n>
			<escape>Back</escape>
			<k mod="ctrl">ActivateWindow(Home)</k>
			<m mod="ctrl">ActivateWindow(Videos,videodb://movies/titles/)</m>
			<t mod="ctrl">ActivateWindow(Videos,videodb://tvshows//titles)</t>
			<f mod="ctrl">ActivateWindow(Videos,sources://video/)</f>
			<p mod="ctrl">ActivateWindow(Videos,special://videoplaylists/)</p>
		</keyboard>
	</global>
	<FullscreenVideo>
		<keyboard>
			<escape>Stop</escape>
		</keyboard>
	</FullscreenVideo>
</keymap>

