2>&1 | 



# functions are stored in an associative array functions, so to get only
# the function names (k flag for keys) in alphabetical order (o flag for
# ordering) you can use:
print -l ${(ok)functions}
# filter out the ones with a leading underscore
print -l ${(ok)functions[(I)[^_]*]}
