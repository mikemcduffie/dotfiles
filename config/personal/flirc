# Alfred workflow for Kodi + Flirc integration workarounds
# HOMEPAGE / Bring Kodi to front (focus) via single remote button
# Use 'related apps' tab on the workflow Hot Key trigger to execute applescript below if the apps "Don't have focus", otherwise pass thru
on run
    tell application "Kodi" to activate
end run
# add to ~/LibraryApplication Support/Kodi/userdata/keymaps/keyboard.xml
<keymap>
	<global>
		<keyboard>
			<n>NextAudioLanguage</n>
			<escape>Back</escape>
			<k mod="ctrl">ActivateWindow(Home)</k>
			<m mod="ctrl">ActivateWindow(Videos,videodb://movies/titles/)</m>
			<m mod="ctrl,command">ActivateWindow(Videos,videodb://movies/genres/)</m>
			<t mod="ctrl">ActivateWindow(Videos,videodb://tvshows//titles)</t>
			<t mod="ctrl,command">ActivateWindow(Videos,videodb://tvshows//genres)</t>
			<f mod="ctrl"ActivateWindow(Videos,sources://video/)</f>
			<p mod="ctrl">ActivateWindow(Videos,special://videoplaylists/)</p>
		</keyboard>
	</global>
	<FullscreenVideo>
		<keyboard>
			<escape>Stop</escape>
		</keyboard>
	</FullscreenVideo>
</keymap>
# "Kill Kodi" Alfred Workflow
flirc_util record_lp F12
# use F12 when Kodi has focus via trigger "related apps" tab to run script
ps -ax | grep Kodi| grep -v grep | awk '{print $1}' | xargs kill -9
# or
killall Kodi
