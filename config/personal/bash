# die "error msg"
die() { echo "$*" 1>&2 ; exit 1; }
❯ die "$0: Kaboom!"
# die exit-staus "error msg"
die() {
  local rc=$1
  shift
  printf '%s\n' "$*" >&2
  exit "$rc"
}
# Alt version
function die () {
  local message=$1
  [ -z "$message" ] && message="Died"
  echo "$message (at ${BASH_SOURCE[1]}:${FUNCNAME[1]} line ${BASH_LINENO[0]}.)" >&2
  exit 1
}
# trap command to catch errors and invoking the die() function
trap die ERR
# check if a file exists and calls the die() function with an error message if it does not.
[ ! -f "$file" ] && die "$0: File $file not found."

