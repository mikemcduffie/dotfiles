# Check File Existence in Bash To test if one of multiple files exists in
# bash or zsh, you can use various methods depending on your specific
# requirements. Here are some approaches:
# Using [[ -f ... ]] with logical OR (||): You can check if any of the
# files exist using the [[ -f ... ]] condition with the logical OR
# operator. For example:
if [[ -f file1 || -f file2 || -f file3 ]]; then
    echo "At least one file exists."
else
    echo "No files exist."
fi
# This method checks if any of the specified files exist.
# Using glob patterns with [[ -n ... ]]: If you want to check for files
# matching a pattern, you can use glob patterns with the [[ -n ... ]]
# condition. For example:
if [[ -n *.abc || -n *.bak || -n *.tmp || -f tmpout.wrk ]]; then
    echo "At least one file exists."
else
    echo "No files exist."
fi
# This method checks if any files with the specified extensions or a
# specific file name exist. Using arrays and checking the array length:
# You can create an array of files matching a pattern and check the length
# of the array. For example:
files=(*.abc *.bak *.tmp)
if (( ${#files[@]} > 0 )); then
    echo "At least one file exists."
else
    echo "No files exist."
fi
# This method checks if there are any files matching the specified
# patterns. Using nullglob to handle no matches: If you want to avoid
# error messages when no files match, you can use the nullglob option.
# For example:
shopt -s nullglob
files=(*.abc *.bak *.tmp)
if (( ${#files[@]} > 0 )); then
    echo "At least one file exists."
else
    echo "No files exist."
fi
# This method ensures that the array is empty if no files match, avoiding
# error messages. Using find command: You can use the find command to
# check if any of the files exist. For example:
if find . -maxdepth 1 -type f $ -name "*.abc" -o -name "*.bak" -o -name "*.tmp" -o -name "tmpout.wrk" $ -print -quit | grep -q .; then
    echo "At least one file exists."
else
    echo "No files exist."
fi








