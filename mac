scpt2applescript() {
    for arg in "$@"; do
        if [[ "$fullpath:t:e" == "scpt" ]]; then
            doosadecompile "$arg" > "${arg/.scpt/.applescript}"
        else
            echo "FileTypeError: $arg"
        fi
    done
}

